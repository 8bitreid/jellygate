# Server
LISTEN_ADDR=:8080
BASE_URL=https://invites.yourdomain.com
SECURE_COOKIES=true
BEHIND_PROXY=true

# Jellyfin API URL — used internally for API calls
JELLYFIN_URL=http://host.docker.internal:8096

# Public-facing Jellyfin URL — shown to users in the onboarding tutorial
MEDIA_URL=https://jellyfin.yourdomain.com

# Seerr URL — optional, shown in tutorial for media requests (leave blank to hide that step)
SEERR_URL=

# Database
DATABASE_URL=postgres://jellygate:changeme@127.0.0.1:5432/jellygate?sslmode=disable
DB_PASSWORD=changeme

# Notifications (optional — leave blank to disable)
DISCORD_WEBHOOK_URL=
